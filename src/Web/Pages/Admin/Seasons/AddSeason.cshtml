@page "/Admin/Seasons/Add"
@model BldLeague.Web.Pages.Admin.Seasons.AddSeason

<div class="container mt-2">
    <h2>Nowy sezon</h2>
    <form method="post" class="mx-auto" style="max-width: 400px;">
        <div class="mb-3">
            <label asp-for="CreateSeasonRequest.SeasonNumber" class="form-label">Numer sezonu</label>
            <input asp-for="CreateSeasonRequest.SeasonNumber" type="number" class="form-control" />
            <span asp-validation-for="CreateSeasonRequest.SeasonNumber" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Dodaj</button>
        <a asp-page="/Admin/Seasons/AllSeasons" class="btn btn-outline-secondary ms-2">Anuluj</a>
    </form>
</div>
