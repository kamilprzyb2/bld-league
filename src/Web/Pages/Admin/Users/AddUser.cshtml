@page "/Admin/Users/Add"
@model BldLeague.Web.Pages.Admin.Users.AddUser

<div class="container mt-2">
    <h2>Dodaj użytkownika</h2>
    <form method="post">
        <div class="mb-3">
            <label asp-for="CreateUserRequest.FullName" class="form-label">Imię i nazwisko</label>
            <input asp-for="CreateUserRequest.FullName" class="form-control" placeholder="Podaj pełne imię i nazwisko">
            <span asp-validation-for="CreateUserRequest.FullName"class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CreateUserRequest.WcaId" class="form-label">WCA ID</label>
            <input asp-for="CreateUserRequest.WcaId" class="form-control" placeholder="Podaj WCA ID">
            <span asp-validation-for="CreateUserRequest.WcaId"class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CreateUserRequest.AvatarImageUrl" class="form-label">Awatar URL</label>
            <input asp-for="CreateUserRequest.AvatarImageUrl" class="form-control" placeholder="Podaj link do awatara (opcjonalne)">
            <span asp-validation-for="CreateUserRequest.AvatarImageUrl"class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="CreateUserRequest.IsAdmin" class="form-check-input" type="checkbox" id="isAdmin">
            <label class="form-check-label" for="isAdmin">Administrator</label>
        </div>

        <button type="submit" class="btn btn-primary">Dodaj</button>
    </form>
</div>